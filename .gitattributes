# Convention line endings — empêche les "faux modified" lors d'opérations cross-OS
# (Linux sandbox, WSL, etc.) sur le repo Windows.

# Texte = autodétection. Git normalise en LF dans le repo, CRLF au checkout Windows.
* text=auto

# Forcer LF pour les fichiers où c'est indispensable (shells Linux, configs)
*.sh    text eol=lf
*.py    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.toml  text eol=lf
*.ini   text eol=lf
*.cfg   text eol=lf

# Forcer CRLF pour les scripts Windows
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Marquer comme binaires (pas de transformation)
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.svg   binary
*.pdf   binary
*.zip   binary
*.gz    binary
*.tar   binary
*.exe   binary
*.dll   binary
*.so    binary
*.sqlite binary
*.db    binary
*.pkl   binary
