# Copy this file to .env and fill your real values
# PowerShell: Copy-Item .env.example .env


# ===============================
# Crypto AI Terminal - .env.example
# ===============================
# Copiez ce fichier en .env et complétez les valeurs nécessaires
# Toutes les variables sont optionnelles sauf mention contraire

# --- Sécurité VPS — réconciliation main/feat/stack-unification (2026-07) ---
# Source de vérité UNIQUE, partagée par scripts/deploy_vps.sh --restart et
# watchdog_vps.py. Tant que 1 : aucune relance automatique du moteur n'est
# tentée nulle part (core/advisor_loop.py absent du disque VPS depuis le
# checkout du 2026-07-02) — alerte seule. Voir RECOVERY.md. Repasser à 0
# uniquement lors de la manœuvre de réconciliation coordonnée.
RESTART_DISABLED_UNTIL_RECONCILIATION=1

# --- Notifications & Alertes ---
# Token du bot Telegram (optionnel)
TELEGRAM_BOT_TOKEN=
# ID du chat Telegram (optionnel)
TELEGRAM_CHAT_ID=
# Chat/groupe dédié au canal comportemental ([BEHAVIOR], transitions, BSM).
# Même bot que TELEGRAM_BOT_TOKEN, destination différente — fallback sur
# TELEGRAM_CHAT_ID si vide.
TELEGRAM_BEHAVIOR_CHAT_ID=
# Symbole surveillé par l'alerte (ex: BTC/USDT)
ALERT_SYMBOL=BTC/USDT
# Timeframe de l'alerte (ex: 1h)
ALERT_TIMEFRAME=1h
# Fréquence de scan (secondes)
ALERT_POLL_SECONDS=45

# --- Telegram — identités multiples (cf Sprint T1, 2026-07-05/06) ---
# Le projet utilise PLUSIEURS bots Telegram distincts. Ne JAMAIS réutiliser
# le token d'un bot pour un autre usage (cause exacte du zombie
# "paper-arena.service" qui envoyait sous l'identité du bot compte réel).
#
# TELEGRAM_BOT_TOKEN        — bot principal (alertes, watchdog, killswitch,
#                             canal [BEHAVIOR]). ~15 fichiers, in-process
#                             dans crypto-advisor.service + crypto_watchdog.service.
# P10_PORTFOLIO_BOT_TOKEN   — @mon_portfolio_bot / CommandCenter. Seul poller :
#                             capital_deployment/command_center_bot.py, importé
#                             par core/advisor_loop.py (in-process, crypto-advisor.service).
#                             Ne PAS lancer src/telegram/portfolio_bot.py en parallèle
#                             (archivé — cf _ARCHIVE_2026/telegram_bot_duplicates_20260706/) :
#                             deux pollers getUpdates sur le même token = conflit 409.
P10_PORTFOLIO_BOT_TOKEN=
P10_PORTFOLIO_CHAT_ID=
# REAL_ACCOUNT_BOT_TOKEN    — bot "Compte Réel" (solde API, STANDBY/LIVE,
#                             "Statut Compte Réel" périodique). Émis par
#                             core/advisor_loop.py::_telegram_real(), tous les
#                             REAL_BOT_REPORT_EVERY cycles. In-process, crypto-advisor.service.
REAL_ACCOUNT_BOT_TOKEN=
REAL_ACCOUNT_CHAT_ID=
REAL_BOT_REPORT_EVERY=12
# INTEL_BOT_TOKEN           — @rapport_automatique_bot, diagnostic complet
#                             toutes les 6h (quant_hedge_ai/agents/intelligence/
#                             system_intel_reporter.py). In-process, crypto-advisor.service.
INTEL_BOT_TOKEN=
INTEL_BOT_CHAT_ID=
# PAPER_ARENA_TG_TOKEN      — bot dédié à src/paper/paper_runner.py
#                             (paper-arena.service, stratégie ETH 4h RSI
#                             indépendante du moteur principal). DOIT avoir
#                             sa PROPRE valeur, jamais celle de REAL_ACCOUNT_BOT_TOKEN.
PAPER_ARENA_TG_TOKEN=
PAPER_ARENA_TG_CHAT_ID=
# CMVK_BOT_TOKEN            — @FtnTrading_bot (SimBot, src/telegram/sim_bot.py
#                             + bot_runner.py). Aucun service systemd committé —
#                             lancement manuel (python -m src.telegram.bot_runner).
CMVK_BOT_TOKEN=
CMVK_CHAT_ID=

# --- Exécution principale V9.1 ---
# Nombre maximum de cycles (0 = infini)
#V9_MAX_CYCLES=5
# Taille de la population de stratégies
#V9_POPULATION=300
# Pause entre cycles (secondes)
#V9_SLEEP_SECONDS=2
# Graine aléatoire (reproductibilité)
#V9_SEED=42

# --- Données de marché ---
# Nombre de chandeliers générés
#V9_MARKET_CANDLES=500
# Lookback pour les features
#V9_LOOKBACK_PERIOD=100
# Volatilité synthétique
#V9_MARKET_VOLATILITY=0.03
# Force de la tendance (0.0-1.0)
#V9_TREND_STRENGTH=0.5

# --- Algorithme génétique ---
# Générations par cycle
#V9_GENERATIONS=3
# Taux de mutation (0.0-1.0)
#V9_MUTATION_RATE=0.15
# Taux de crossover (0.0-1.0)
#V9_CROSSOVER_RATE=0.7
# Nombre d'élites
#V9_ELITE_COUNT=10

# --- Gestion du risque ---
# Facteur de sécurité Kelly (0.0-1.0)
#V9_KELLY_SAFETY=0.5
# Volatilité cible du portefeuille
#V9_TARGET_VOLATILITY=0.15
# Poids max d'une position
#V9_MAX_POSITION_WEIGHT=0.30
# Sharpe minimum pour trader
#V9_MIN_SHARPE=2.0
# Drawdown max autorisé
#V9_MAX_DRAWDOWN=0.10

# --- Whale Radar ---
# Seuil transaction baleine (USD)
#V9_WHALE_THRESHOLD=500000
# Seuil de blocage whale
#V9_WHALE_BLOCK_THRESHOLD=2
# Lookback whale
#V9_WHALE_LOOKBACK=50

# --- Backtest ---
# Slippage par trade (%)
#V9_SLIPPAGE=0.001
# Commission par trade (%)
#V9_COMMISSION=0.001
# Capital initial
#V9_INITIAL_CAPITAL=100000
# Simulations Monte Carlo
#V9_MONTECARLO_SIMULATIONS=1000
# Choc max Monte Carlo (%)
#V9_MONTECARLO_MAX_SHOCK=95

# --- Logging & Output ---
# Niveau de log (DEBUG, INFO, WARNING, ERROR)
#V9_LOG_LEVEL=INFO
# Logs détaillés par cycle
#V9_DEBUG_CYCLES=false
# Sauvegarder toutes les stratégies
#V9_SAVE_ALL_STRATEGIES=false
# Fréquence d'affichage dashboard
#V9_DISPLAY_FREQUENCY=1

# ──────────────────────────────────────────────────────────────────────────────
# EXCHANGE — sélection de la plateforme (exchange_factory.py)
# ──────────────────────────────────────────────────────────────────────────────
# ID CCXT de l'exchange actif.
# Valeurs supportées : binance | kraken | gateio | bybit | okx | coinbase
# Défaut : binance
EXCHANGE_ID=kraken

# Mode testnet/sandbox de l'exchange (true = sandbox, false = marché réel)
# IMPORTANT : sans clés API → mode paper automatique (données live, ordres simulés)
EXCHANGE_TESTNET=false

# --- Kraken (recommandé pour le Canada — meilleure conformité réglementaire) ---
# Laisser vide pour le mode paper (données live gratuites, zéro risque)
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# --- Gate.io (alternative — très bonne API, CCXT natif) ---
GATEIO_API_KEY=
GATEIO_API_SECRET=

# --- Binance (historique — moins recommandé Canada) ---
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=false

# --- Compte n°1 — observation passive des soldes réels (ADR-0007) ---
# Chaque exchange dont {EX}_API_KEY + {EX}_API_SECRET sont renseignés est lu
# en LECTURE SEULE : panneau « COMPTE N°1 » dans le rapport 15 min + détail
# par actif sur le bot compte réel (@PaperArena_bot). Affichage uniquement,
# jamais le sizing. Clés API : créer en read-only + IP whitelist du VPS.
#REAL_ACCOUNTS_EXCHANGES=mexc,binance
#REAL_ACCOUNTS_TTL_S=900
#REAL_ACCOUNTS_DUST_USD=0.50

# --- Safety layer (chantier 3) ---
# Fenêtre de déduplication des ordres en secondes (défaut: 30)
#EXEC_DEDUP_WINDOW=30
# Drawdown max de session avant halt automatique (défaut: 5%)
#EXEC_MAX_DD=0.05
# Perte max de session avant halt automatique (défaut: 3%)
#EXEC_MAX_LOSS=0.03
# Pertes consécutives max avant halt (défaut: 3)
#EXEC_MAX_CONSEC_LOSSES=3
# Taille max d'un ordre en USD (défaut: 10 000)
#EXEC_MAX_ORDER_USD=10000
# Chemin du log SQLite des ordres
#EXEC_TRADE_LOG=databases/trade_log.sqlite

# --- Gate d'exécution réelle (SEC-01, 2026-07-08) ---
# PAPER_TRADING_ENABLED=true (défaut) bloque tout ordre réel au point d'entrée
# de ExecutionEngine._place_live_order() — plus un flag narratif, un vrai
# garde-fou de code. Lu à l'appel (DS-001), jamais figé.
PAPER_TRADING_ENABLED=true
# LIVE_TRADING_CONFIRMED — 2e ligne de défense. ExecutionEngine.from_env() ne
# peut plus produire un moteur live sur la seule présence de clés API : ce
# flag doit AUSSI valoir true. À ne poser QUE lors d'une activation
# volontaire du trading réel, suivant une procédure de checklist dédiée —
# jamais par défaut, jamais comme effet de bord d'une autre config.
LIVE_TRADING_CONFIRMED=false

# --- LM Studio local AI ---
# Petit modèle recommandé sur machine modeste.
# Chargez le même modèle dans LM Studio > Local Server avant de lancer advisor_loop.py.
#LM_STUDIO_MODEL=qwen2.5-3b-instruct.gguf
# Timeout max pour une réponse locale LM Studio (secondes)
#LM_STUDIO_TIMEOUT=20

# ──────────────────────────────────────────────────────────────────────────────
# DECISION PACKETS — traces cognitives (advisor_loop.py)
# ──────────────────────────────────────────────────────────────────────────────
# Répertoire de stockage des traces JSONL (rotation quotidienne automatique).
# Format : {DP_LOG_DIR}/decision_packets_YYYY-MM-DD.jsonl
# Sur VPS : pointer vers un volume persistant (ex. /opt/crypto_ai_terminal/data/logs)
#DP_LOG_DIR=databases

# Chemin fixe (désactive la rotation — compat legacy).
# Si défini, DP_LOG_DIR est ignoré.
#DP_LOG_PATH=databases/decision_packets.jsonl

# --- Scanner marché ---
# Timeframe OHLCV pour le scanner (défaut: 1h)
#MARKET_SCANNER_TIMEFRAME=1h
# Bougies historiques à récupérer (défaut: 200)
#MARKET_SCANNER_LIMIT=200

# --- Intégrations externes (exemples) ---
#SLACK_WEBHOOK_URL=
#EMAIL_SMTP_SERVER=
#EMAIL_FROM_ADDR=
#EMAIL_TO_ADDR=

# Toutes les variables sont optionnelles sauf mention contraire. Voir CONFIG_REFERENCE_V91.md pour la liste complète et la signification de chaque paramètre.
