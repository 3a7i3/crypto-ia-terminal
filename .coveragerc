[run]
branch = True

[report]
show_missing = True
skip_empty = True
include =
    # Supervision & alertes
    supervision/alert_manager.py
    supervision/bot_doctor.py
    supervision/custom_module.py
    supervision/botdoctor_dashboard.py
    supervision/ops_watchdog.py
    supervision/notifications/multi_notifier.py
    supervision/notifications/slack_notifier.py
    supervision/notifications/telegram_notifier.py
    supervision/notifications/ops_notifier.py

    # Chantier 1 — pipeline données réelles
    quant_hedge_ai/agents/market/ohlcv_validator.py
    quant_hedge_ai/agents/market/retry_policy.py
    quant_hedge_ai/agents/market/market_scanner.py
    quant_hedge_ai/agents/market/historical_fetcher.py

    # Chantier 2 — validation historique
    quant_hedge_ai/agents/quant/backtest_lab.py
    quant_hedge_ai/agents/quant/walk_forward.py

    # Chantier 3 — sécurité live trading
    quant_hedge_ai/agents/execution/execution_engine.py
    quant_hedge_ai/agents/execution/order_deduplicator.py
    quant_hedge_ai/agents/execution/trade_logger.py
    quant_hedge_ai/agents/execution/paper_trading_engine.py
    quant_hedge_ai/agents/risk/session_guard.py
    quant_hedge_ai/agents/risk/drawdown_guard.py
    quant_hedge_ai/agents/risk/risk_monitor.py
    quant_hedge_ai/agents/intelligence/feature_engineer.py

    # Strategy lab
    quant_hedge_ai/strategy_lab/feature_cache.py

    # Event bus (Phase 3)
    event_bus/bus.py
    event_bus/bridge.py
    event_bus/events.py

    # Intelligence agents (Phase 1 — restaurés)
    quant_hedge_ai/agents/intelligence/regime_detector.py

    # Evolution engine (Phase 3 — branché event bus)
    quant_hedge_ai/ai_evolution/evolution_engine.py

    # Phase 4 — Live Signal Engine
    quant_hedge_ai/agents/execution/live_signal_engine.py

    # Phase 5 — Trade Post-Mortem + Blacklist
    quant_hedge_ai/agents/execution/trade_postmortem.py
    quant_hedge_ai/ai_evolution/strategy_memory.py

    # Phase 6 — AIAdvisor + WeeklyReport
    quant_hedge_ai/agents/intelligence/ai_advisor.py
    quant_hedge_ai/agents/intelligence/weekly_report.py

    # Phase 7 — GlobalRiskGate + OrderSizer
    quant_hedge_ai/agents/risk/global_risk_gate.py
    quant_hedge_ai/agents/risk/order_sizer.py

    # Phase 8 — Alertes proactives, HealthEndpoint, AdvisorOnly
    quant_hedge_ai/agents/intelligence/proactive_alerts.py
    quant_hedge_ai/health_endpoint.py
    quant_hedge_ai/advisor_only_mode.py

exclude_lines =
    pragma: no cover
    if __name__ == .__main__.:
    raise NotImplementedError
    \.\.\.
