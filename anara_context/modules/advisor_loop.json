{
  "module_id": "advisor_loop",
  "class_name": "AdvisorLoop",
  "file_path": "advisor_loop.py",
  "display_name": "Boucle Principale",
  "layer": "infrastructure",
  "dashboard_tab": "Infrastructure",

  "role_fr": "Orchestrateur principal du système. Exécute en boucle les cycles signal → conviction → risk → exécution. Coordonne tous les agents décisionnels.",
  "role_en": "Main system orchestrator. Runs continuous cycles of signal → conviction → risk → execution. Coordinates all decision agents.",

  "cycle_pipeline": [
    { "step": 1, "agent": "LiveSignalEngine",  "output": "SignalResult / DecisionPacket" },
    { "step": 2, "agent": "ConvictionEngine",  "output": "Enrichit le packet — niveau conviction" },
    { "step": 3, "agent": "GlobalRiskGate",    "output": "Pass / Block — 5 conditions" },
    { "step": 4, "agent": "PortfolioBrain",    "output": "Approved / Rejected — 8 checks portfolio" },
    { "step": 5, "agent": "OrderSizer",        "output": "Taille finale en USD" },
    { "step": 6, "agent": "ExecutionEngine",   "output": "Ordre placé (paper/live/rejected)" }
  ],

  "key_metrics": [
    { "metric_id": "cycle_count",       "label": "Cycles total",      "type": "int" },
    { "metric_id": "cycle_duration_ms", "label": "Durée cycle",       "type": "int", "unit": "ms" },
    { "metric_id": "signals_per_hour",  "label": "Signaux/heure",     "type": "float" },
    { "metric_id": "trade_rate",        "label": "Taux exécution",    "type": "percent" },
    { "metric_id": "last_cycle_ts",     "label": "Dernier cycle",     "type": "timestamp" },
    { "metric_id": "status",            "label": "Statut",            "type": "enum",
      "values": ["running", "paused", "halted", "error"],
      "dashboard_color_map": {
        "running": "#22c55e", "paused": "#f59e0b", "halted": "#f97316", "error": "#ef4444"
      }
    }
  ],

  "observability_principles": [
    "Tout rejet visible dans le dashboard avec raison détaillée",
    "duration_ms cognitif enregistré par cycle",
    "Chaque décision tracée dans black_box.jsonl"
  ],

  "env_vars": [
    { "var": "ACTIVE_EXCHANGE",                    "default": "",       "description": "Exchange actif : binance | mexc | hyperliquid (vide = auto-détection)" },
    { "var": "ADVISOR_CYCLE_BUDGET_SECONDS",        "default": "0",      "description": "Budget max par cycle en secondes (0 = illimité)" },
    { "var": "ADVISOR_MTF_REFRESH_EVERY",           "default": "12",     "description": "Rafraîchir les données MTF tous les N cycles" },
    { "var": "ADVISOR_NOTIFY_EVERY",                "default": "3",      "description": "Fréquence des notifications dashboard (cycles)" },
    { "var": "ADVISOR_LOAD_SHED_CYCLES",            "default": "1",      "description": "Nombre de cycles à passer en load-shedding" },
    { "var": "ADVISOR_DEFER_OPTIONAL_INTEL",        "default": "true",   "description": "Différer les couches intelligence optionnelles (ThreatRadar, RegretEngine)" },
    { "var": "ADVISOR_DEFER_POST_CYCLE_SERVICES",   "default": "true",   "description": "Différer les services post-cycle (PostMortem, BlackBox flush)" },
    { "var": "ADVISOR_1H_LIMIT",                    "default": "96",     "description": "Limite de bougies 1H récupérées par cycle" },
    { "var": "ADVISOR_LIVE_EXECUTION_BOOTSTRAP",    "default": "false",  "description": "Activer le bootstrap exécution live au démarrage" },
    { "var": "ADVISOR_PERSISTENT_WARMUP",           "default": "false",  "description": "Maintenir le warmup persistant entre cycles" },
    { "var": "ADVISOR_PREWARM_MTF",                 "default": "false",  "description": "Pré-chauffer les données MTF au démarrage" },
    { "var": "ADVISOR_BACKGROUND_POSITION_WATCH",   "default": "false",  "description": "Activer la surveillance des positions en arrière-plan" }
  ]
}
