# Default Configuration for Crypto AI Trading System V6
# Copy to .env and fill in your values

# Trading Mode (paper/live)
LIVE_TRADING=False
PAPER_TRADING=True

# Debug Settings
DEBUG_MODE=False
LOG_LEVEL=INFO

# API Configuration
API_HOST=localhost
API_PORT=8000
API_WORKERS=4

# Exchange API Keys (if using live trading)
BINANCE_API_KEY=your_binance_key_here
BINANCE_API_SECRET=your_binance_secret_here

BYBIT_API_KEY=your_bybit_key_here
BYBIT_API_SECRET=your_bybit_secret_here

COINBASE_API_KEY=your_coinbase_key_here
COINBASE_PASSPHRASE=your_coinbase_passphrase_here

KRAKEN_API_KEY=your_kraken_key_here
KRAKEN_API_SECRET=your_kraken_secret_here

# Notification Settings
EMAIL_ADDRESS=your_email@example.com
DISCORD_WEBHOOK=https://discordapp.com/api/webhooks/...
TELEGRAM_TOKEN=your_telegram_token
SLACK_WEBHOOK=https://hooks.slack.com/services/...

# System Settings
HEARTBEAT_INTERVAL_SECONDS=60
MAX_RETRIES=3
RETRY_DELAY_SECONDS=5

# Memory & Performance
MAX_MEMORY_MB=2048
ENABLE_PROFILING=False
CACHE_ENABLED=True
