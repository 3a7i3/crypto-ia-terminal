# Ignore log files and large data
logs/
*.log
quant-ai-system/logs/
quant-ai-system/logs/trading_system.log

# Ignore Python cache
__pycache__/
*.pyc

# Ignore Jupyter notebook checkpoints
.ipynb_checkpoints/

# Ignore environment and setup files
.env
.env.*
*.env
venv/
.venv/
setup/

# Ignore API secrets and credentials
secrets.json
secrets.yaml
secrets.yml
*_secret*
*_key*
*_credentials*
api_keys.json

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore data files
data/
*.csv

# Ignore backups and archives
*.broken_backup
*.tar.gz
*.zip
.coverage
archives/

# Ignore SQLite databases et bases de données runtime
*.sqlite
*.db
databases/
*.jsonl

# Ignore temporary files
*.tmp
*.temp
~$*
*.swp
*.bak

# Ignore runtime / generated artifacts
cache/
*.pkl
.portfolio_bot_started
PROJET_MINIATURE.md
PROJET_MINIATURE_FULL.md

# Ignore frontend build artifacts
node_modules/
frontend/node_modules/
frontend/dist/
frontend/build/
dist/
build/
